generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
  relationMode = "foreignKeys"
}

model User {
  id        String   @id @default(cuid()) @db.VarChar(30)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      String   @default("Gestionnaire") @db.VarChar(50)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile     UserProfile?
  entries     Entry[]
  exits       Exit[]
  inventories Inventory[]

  @@map("users")
}

model UserProfile {
  id             String    @id @default(cuid()) @db.VarChar(30)
  userId         String    @unique @map("user_id") @db.VarChar(30)
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  displayName    String    @map("display_name") @db.VarChar(150)
  profilePhoto   String?   @map("profile_photo") @db.VarChar(255)
  phone          String?   @db.VarChar(30)
  secondaryPhone String?   @map("secondary_phone") @db.VarChar(30)
  birthDate      DateTime? @map("birth_date") @db.Date
  gender         String?   @db.VarChar(20)
  address        String?   @db.VarChar(255)
  city           String?   @db.VarChar(100)
  region         String?   @db.VarChar(100)
  country        String?   @db.VarChar(100)
  postalCode     String?   @map("postal_code") @db.VarChar(20)
  jobTitle       String?   @map("job_title") @db.VarChar(100)
  department     String?   @db.VarChar(100)
  signature      String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Category {
  id          String   @id @default(cuid()) @db.VarChar(30)
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  products    Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(cuid()) @db.VarChar(30)
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  products  Product[]

  @@map("brands")
}

model Unit {
  id        String   @id @default(cuid()) @db.VarChar(30)
  name      String   @unique @db.VarChar(100)
  abbrev    String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  products  Product[]

  @@map("units")
}

model Product {
  id          String   @id @default(cuid()) @db.VarChar(30)
  reference   String   @unique @db.VarChar(50)
  name        String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  price       Float
  stockMin    Int      @default(5) @map("stock_min")
  stockMax    Int?     @map("stock_max")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categoryId String @map("category_id") @db.VarChar(30)
  brandId    String @map("brand_id") @db.VarChar(30)
  unitId     String @map("unit_id") @db.VarChar(30)

  category    Category      @relation(fields: [categoryId], references: [id])
  brand       Brand         @relation(fields: [brandId], references: [id])
  unit        Unit          @relation(fields: [unitId], references: [id])
  stocks      Stock[]
  entries     EntryLine[]
  exitLines   ExitLine[]
  movements   Movement[]
  inventoryLines InventoryLine[]

  @@map("products")
}

model Warehouse {
  id        String   @id @default(cuid()) @db.VarChar(30)
  name      String   @db.VarChar(100)
  location  String?  @db.VarChar(255)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zones    Zone[]
  stocks   Stock[]
  entries       Entry[]
  exits         Exit[]
  fromMovements Movement[] @relation("fromWarehouse")
  toMovements   Movement[] @relation("toWarehouse")
  inventories   Inventory[]

  @@map("warehouses")
}

model Zone {
  id          String   @id @default(cuid()) @db.VarChar(30)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouseId String @map("warehouse_id") @db.VarChar(30)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  stocks    Stock[]

  @@map("zones")
}

model Stock {
  id        String   @id @default(cuid()) @db.VarChar(30)
  quantity  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productId   String @map("product_id") @db.VarChar(30)
  warehouseId String @map("warehouse_id") @db.VarChar(30)
  zoneId      String? @map("zone_id") @db.VarChar(30)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  zone      Zone?     @relation(fields: [zoneId], references: [id])

  @@unique([productId, warehouseId, zoneId])
  @@map("stocks")
}

model Supplier {
  id        String   @id @default(cuid()) @db.VarChar(30)
  name      String   @db.VarChar(100)
  email     String?  @db.VarChar(100)
  phone     String?  @db.VarChar(30)
  address   String?  @db.VarChar(255)
  contact   String?  @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entries Entry[]

  @@map("suppliers")
}

model Entry {
  id          String   @id @default(cuid()) @db.VarChar(30)
  reference   String   @unique @db.VarChar(50)
  date        DateTime @default(now())
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  supplierId String @map("supplier_id") @db.VarChar(30)
  userId     String @map("user_id") @db.VarChar(30)

  supplier Supplier   @relation(fields: [supplierId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  lines    EntryLine[]
  warehouseId String  @map("warehouse_id") @db.VarChar(30)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("entries")
}

model EntryLine {
  id        String   @id @default(cuid()) @db.VarChar(30)
  quantity  Int
  unitPrice Float @map("unit_price")
  createdAt DateTime @default(now()) @map("created_at")

  entryId   String @map("entry_id") @db.VarChar(30)
  productId String @map("product_id") @db.VarChar(30)

  entry   Entry   @relation(fields: [entryId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("entry_lines")
}

model Exit {
  id          String   @id @default(cuid()) @db.VarChar(30)
  reference   String   @unique @db.VarChar(50)
  date        DateTime @default(now())
  type        String   @default("vente") @db.VarChar(30)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId      String @map("user_id")
  warehouseId String @map("warehouse_id")

  user      User       @relation(fields: [userId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  lines     ExitLine[]

  @@map("exits")
}

model ExitLine {
  id        String   @id @default(cuid()) @db.VarChar(30)
  quantity  Int
  unitPrice Float @map("unit_price")
  createdAt DateTime @default(now()) @map("created_at")

  exitId    String @map("exit_id") @db.VarChar(30)
  productId String @map("product_id") @db.VarChar(30)

  exit    Exit    @relation(fields: [exitId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("exit_lines")
}

model Movement {
  id        String   @id @default(cuid()) @db.VarChar(30)
  type      String   @db.VarChar(30)
  quantity  Int
  date      DateTime @default(now())
  description String? @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  productId   String @map("product_id") @db.VarChar(30)
  fromWarehouseId String? @map("from_warehouse_id") @db.VarChar(30)
  toWarehouseId   String? @map("to_warehouse_id") @db.VarChar(30)

  product      Product    @relation(fields: [productId], references: [id])
  fromWarehouse Warehouse? @relation("fromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("toWarehouse", fields: [toWarehouseId], references: [id])

  @@map("movements")
}

model Inventory {
  id          String   @id @default(cuid()) @db.VarChar(30)
  reference   String   @unique @db.VarChar(50)
  date        DateTime @default(now())
  status      String   @default("en_cours") @db.VarChar(30)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId      String @map("user_id") @db.VarChar(30)
  warehouseId String @map("warehouse_id") @db.VarChar(30)

  user      User       @relation(fields: [userId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  lines     InventoryLine[]

  @@map("inventories")
}

model InventoryLine {
  id          String   @id @default(cuid()) @db.VarChar(30)
  expectedQty Int @map("expected_qty")
  actualQty   Int @map("actual_qty")
  difference  Int
  createdAt   DateTime @default(now()) @map("created_at")

  inventoryId String @map("inventory_id") @db.VarChar(30)
  productId   String @map("product_id") @db.VarChar(30)

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@map("inventory_lines")
}

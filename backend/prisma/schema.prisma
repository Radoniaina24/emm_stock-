generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("Gestionnaire")
  phone     String?
  avatar    String?
  department String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entries    Entry[]
  exits      Exit[]
  inventories Inventory[]

  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  products    Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  products  Product[]

  @@map("brands")
}

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  abbrev    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  products  Product[]

  @@map("units")
}

model Product {
  id          String   @id @default(cuid())
  reference   String   @unique
  name        String
  description String?
  price       Float
  stockMin    Int      @default(5) @map("stock_min")
  stockMax    Int?     @map("stock_max")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categoryId String @map("category_id")
  brandId    String @map("brand_id")
  unitId     String @map("unit_id")

  category    Category      @relation(fields: [categoryId], references: [id])
  brand       Brand         @relation(fields: [brandId], references: [id])
  unit        Unit          @relation(fields: [unitId], references: [id])
  stocks      Stock[]
  entries     EntryLine[]
  exitLines   ExitLine[]
  movements   Movement[]
  inventoryLines InventoryLine[]

  @@map("products")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zones    Zone[]
  stocks   Stock[]
  entries       Entry[]
  exits         Exit[]
  fromMovements Movement[] @relation("fromWarehouse")
  toMovements   Movement[] @relation("toWarehouse")
  inventories   Inventory[]

  @@map("warehouses")
}

model Zone {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouseId String @map("warehouse_id")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  stocks    Stock[]

  @@map("zones")
}

model Stock {
  id        String   @id @default(cuid())
  quantity  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productId   String @map("product_id")
  warehouseId String @map("warehouse_id")
  zoneId      String? @map("zone_id")

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  zone      Zone?     @relation(fields: [zoneId], references: [id])

  @@unique([productId, warehouseId, zoneId])
  @@map("stocks")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  contact   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entries Entry[]

  @@map("suppliers")
}

model Entry {
  id          String   @id @default(cuid())
  reference   String   @unique
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  supplierId String @map("supplier_id")
  userId     String @map("user_id")

  supplier Supplier   @relation(fields: [supplierId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  lines    EntryLine[]
  warehouseId String  @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("entries")
}

model EntryLine {
  id        String   @id @default(cuid())
  quantity  Int
  unitPrice Float @map("unit_price")
  createdAt DateTime @default(now()) @map("created_at")

  entryId   String @map("entry_id")
  productId String @map("product_id")

  entry   Entry   @relation(fields: [entryId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("entry_lines")
}

model Exit {
  id          String   @id @default(cuid())
  reference   String   @unique
  date        DateTime @default(now())
  type        String   @default("vente")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId      String @map("user_id")
  warehouseId String @map("warehouse_id")

  user      User       @relation(fields: [userId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  lines     ExitLine[]

  @@map("exits")
}

model ExitLine {
  id        String   @id @default(cuid())
  quantity  Int
  unitPrice Float @map("unit_price")
  createdAt DateTime @default(now()) @map("created_at")

  exitId    String @map("exit_id")
  productId String @map("product_id")

  exit    Exit    @relation(fields: [exitId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("exit_lines")
}

model Movement {
  id        String   @id @default(cuid())
  type      String
  quantity  Int
  date      DateTime @default(now())
  description String?
  createdAt DateTime @default(now()) @map("created_at")

  productId   String @map("product_id")
  fromWarehouseId String? @map("from_warehouse_id")
  toWarehouseId   String? @map("to_warehouse_id")

  product      Product    @relation(fields: [productId], references: [id])
  fromWarehouse Warehouse? @relation("fromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("toWarehouse", fields: [toWarehouseId], references: [id])

  @@map("movements")
}

model Inventory {
  id          String   @id @default(cuid())
  reference   String   @unique
  date        DateTime @default(now())
  status      String   @default("en_cours")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId      String @map("user_id")
  warehouseId String @map("warehouse_id")

  user      User       @relation(fields: [userId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  lines     InventoryLine[]

  @@map("inventories")
}

model InventoryLine {
  id          String   @id @default(cuid())
  expectedQty Int @map("expected_qty")
  actualQty   Int @map("actual_qty")
  difference  Int
  createdAt   DateTime @default(now()) @map("created_at")

  inventoryId String @map("inventory_id")
  productId   String @map("product_id")

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@map("inventory_lines")
}
